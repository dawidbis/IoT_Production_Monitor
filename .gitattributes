# Normalise line endings so the repo is consistent across Windows/Linux CI agents.
* text=auto

# Cross-platform source: LF in the repository
*.cs    text eol=lf
*.csproj text eol=lf
*.sln   text eol=crlf
*.tf    text eol=lf
*.tfvars text eol=lf
*.yml   text eol=lf
*.yaml  text eol=lf
*.json  text eol=lf
*.md    text eol=lf
Dockerfile text eol=lf
.dockerignore text eol=lf

# PowerShell: keep CRLF (Windows-first tooling convention)
*.ps1   text eol=crlf
*.psm1  text eol=crlf
*.psd1  text eol=crlf

# Binaries
*.png binary
*.jpg binary
*.ico binary
